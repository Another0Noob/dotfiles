function abbreviations
    abbr --add cd z
    abbr --add .. 'z ..'
    abbr --add man batman
    abbr --add find fd
    abbr --add fd 'fd -H'
    abbr --add ls 'eza --icons'
    abbr --add ll 'eza --icons -lb'
    abbr --add la 'eza --icons -lag'
    abbr --add tree 'eza --icons -T'
    abbr --add cat bat
    abbr --add chez 'z ~/.local/share/chezmoi/'
    abbr --add n nvim
end
